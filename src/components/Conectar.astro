<section id="conectar" data-reveal-container class="min-h-[calc(70vh-1rem)] content-section relative overflow-hidden isolation-isolate w-[calc(100%-32px)] md:w-full max-w-7xl mx-auto rounded-[32px] py-12 my-12" data-stagger="true">

  <div class="max-w-3xl mx-auto px-6 text-center space-y-6">

    <h2 class="text-4xl font-black tracking-tight text-foreground" data-animate="fade-up">
      Vamos transformar design em código escalável?
    </h2>

    <p 
      class="text-lg text-muted-foreground" data-animate="fade-up"
    >
      Fique à vontade para me acionar para contratos, consultorias de DesignOps ou posições core de Product Design.
    </p>

    <form
      id="contact-form"
      class="mt-12 max-w-3xl mx-auto space-y-6 text-left"
      novalidate
      action="https://maxebina.com.br/send-email.php"
      method="POST"
    >
      <!-- Honeypot anti-spam -->
      <input
        type="text"
        name="website"
        tabindex="-1"
        autocomplete="off"
        class="hidden"
      />
      
      <fieldset class="space-y-6">

        <!-- Nome + Telefone -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-animate="fade-up">

          <div>
            <label
              for="nome"
              class="block text-sm font-medium mb-2 text-foreground"
            >
              Nome
            </label>

            <input
              id="nome"
              name="nome"
              type="text"
              autocomplete="name"
              required
              aria-describedby="nome-error"
              placeholder="Seu nome"
              class="w-full rounded-xl border border-border bg-background px-4 py-3 outline-none transition focus:border-primary"
            />

            <p
              id="nome-error"
              class="mt-2 text-sm text-destructive hidden"
            >
              Informe seu nome.
            </p>
          </div>

          <div>
            <label
              for="telefone"
              class="block text-sm font-medium mb-2 text-foreground"
            >
              Telefone
            </label>

            <input
              id="telefone"
              name="telefone"
              type="tel"
              autocomplete="tel"
              required
              aria-describedby="telefone-error"
              placeholder="(11) 99999-9999"
              class="w-full rounded-xl border border-border bg-background px-4 py-3 outline-none transition focus:border-primary"
            />

            <p
              id="telefone-error"
              class="mt-2 text-sm text-destructive hidden"
            >
              Informe um telefone válido.
            </p>
          </div>

        </div>

        <!-- Email -->
        <div data-animate="fade-up">
          <label
            for="email"
            class="block text-sm font-medium mb-2 text-foreground"
          >
            E-mail
          </label>

          <input
            id="email"
            name="email"
            type="email"
            autocomplete="email"
            required
            aria-describedby="email-error"
            placeholder="voce@empresa.com"
            class="w-full rounded-xl border border-border bg-background px-4 py-3 outline-none transition focus:border-primary"
          />

          <p
            id="email-error"
            class="mt-2 text-sm text-destructive hidden"
          >
            Informe um e-mail válido.
          </p>
        </div>

        <!-- Assunto -->
        <div data-animate="fade-up">
          <label
            for="assunto"
            class="block text-sm font-medium mb-2 text-foreground"
          >
            Assunto
          </label>

          <select
            id="assunto"
            name="assunto"
            required
            aria-describedby="assunto-error"
            class="w-full rounded-xl border border-border bg-background px-4 py-3 outline-none transition focus:border-primary"
          >
            <option value="">
              Selecione uma opção
            </option>

            <option value="product-design">
              Product Design
            </option>

            <option value="design-system">
              Design System
            </option>

            <option value="designops">
              Consultoria DesignOps
            </option>

            <option value="freelance">
              Projeto Freelancer
            </option>

            <option value="hiring">
              Oportunidade de Contratação
            </option>

            <option value="other">
              Outro assunto
            </option>
          </select>

          <p
            id="assunto-error"
            class="mt-2 text-sm text-destructive hidden"
          >
            Selecione um assunto.
          </p>
        </div>

        <!-- Mensagem -->
        <div data-animate="fade-up">
          <label
            for="mensagem"
            class="block text-sm font-medium mb-2 text-foreground"
          >
            Mensagem
          </label>

          <textarea
            id="mensagem"
            name="mensagem"
            rows="6"
            required
            aria-describedby="mensagem-error"
            placeholder="Conte um pouco sobre seu projeto, desafio ou oportunidade."
            class="w-full rounded-xl border border-border bg-background px-4 py-3 outline-none transition resize-y focus:border-primary"
          ></textarea>

          <p
            id="mensagem-error"
            class="mt-2 text-sm text-destructive hidden"
          >
            Escreva uma mensagem.
          </p>
        </div>

        <!-- Submit -->
        <div class="pt-2" data-animate="fade-up">
          <button
            type="submit"
            class="form-submit inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 font-semibold text-white transition hover:opacity-90 cursor-pointer"
          >
            Enviar mensagem
          </button>
        </div>

      </fieldset>
    </form>

  </div>
</section>