<div
  id="case-modal"
  class="
    fixed
    inset-0
    z-[9999]
    hidden
    items-center
    justify-center
    opacity-0
    transition-opacity
    duration-300
  "
>
  <div
    class="absolute inset-0 bg-black/80 backdrop-blur-sm"
    data-close="modal"
  ></div>

  <div
    class="
        relative
        z-10
        w-full
        max-w-6xl
        mx-1
        md:mx-6
        p-2
        md:p-8
        bg-background
        rounded-3xl
        shadow-2xl
        flex
        flex-col
        max-h-[90vh]
        overflow-hidden
    "
  >
    <div
      class="
        flex-none
        flex
        justify-end
        items-center
        gap-2
        mb-4
      "
    >
      <button
        id="case-modal-prev"
        type="button"
        class="group flex items-center justify-center w-10 h-10 rounded-full border border-border/50 text-muted-foreground text-2xl md:text-base transition-all duration-300 hover:border-foreground/40 hover:bg-foreground/5 cursor-pointer disabled:opacity-30 disabled:pointer-events-none"
      >
        <i class="ph ph-bold ph-arrow-left"></i>
      </button>

      <button
        id="case-modal-next"
        type="button"
        class="group flex items-center justify-center w-10 h-10 rounded-full border border-border/50 text-muted-foreground text-2xl md:text-base transition-all duration-300 hover:border-foreground/40 hover:bg-foreground/5 cursor-pointer disabled:opacity-30 disabled:pointer-events-none"
      >
        <i class="ph ph-bold ph-arrow-right"></i>
      </button>

      <button
        data-close="modal"
        class="group flex items-center justify-center w-10 h-10 rounded-full border border-border/50 text-muted-foreground text-2xl md:text-base transition-all duration-300 hover:border-foreground/40 hover:bg-foreground/5 cursor-pointer"
      >
        <i class="ph ph-bold ph-x"></i>
      </button>
    </div>

    <div class="flex-1 overflow-y-auto w-full">
      <img
        id="case-modal-image"
        src=""
        alt=""
        class="w-full h-auto block rounded-2xl"
      />

      <iframe
        id="case-modal-figma"
        class="hidden w-full h-[80vh] rounded-2xl"
      ></iframe>
    </div>

    <div class="flex-none mt-4">
      <p
        id="case-modal-caption"
        class="text-center text-sm text-muted-foreground"
      ></p>
    </div>
  </div>
</div>