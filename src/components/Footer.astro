<footer 
  id="main-footer"
  class="w-[calc(100%-16px)] mx-auto mb-2 rounded-2xl border-b border-border bg-muted backdrop-blur-sm py-6 px-6
         shadow-[0_-8px_32px_rgba(0,0,0,0.06)]
         dark:shadow-[0_-8px_32px_rgba(0,0,0,0.4)]"
>

  <div class="max-w-7xl mx-auto flex flex-col gap-4 md:grid md:grid-cols-[1fr_auto_1fr] md:items-center">

    <!-- LEFT -->
    <div class="flex items-center justify-center md:justify-start">
      <p class="text-xs text-muted-foreground whitespace-nowrap">
        © {new Date().getFullYear()} Max.productdesigner
      </p>
    </div>

    <!-- CENTER -->
    <nav class="flex flex-wrap items-center justify-center gap-4 md:gap-6">
      <a href="#cases" class="nav-link relative py-1 text-sm font-medium text-[var(--muted-foreground)] transition-colors duration-300 hover:text-[var(--foreground)] before:absolute before:bottom-0 before:left-0 before:h-[2px] before:w-full before:scale-x-0 before:bg-[var(--foreground)] before:transition-transform before:duration-300 before:ease-out before:origin-right hover:before:scale-x-100 hover:before:origin-left">
        Cases
      </a>

      <a href="#sobre" class="nav-link relative py-1 text-sm font-medium text-[var(--muted-foreground)] transition-colors duration-300 hover:text-[var(--foreground)] before:absolute before:bottom-0 before:left-0 before:h-[2px] before:w-full before:scale-x-0 before:bg-[var(--foreground)] before:transition-transform before:duration-300 before:ease-out before:origin-right hover:before:scale-x-100 hover:before:origin-left">
        Sobre
      </a>

      <a 
        href="#conectar"
        data-section="conectar"
        class="nav-link relative py-1 text-sm font-medium text-[var(--muted-foreground)] transition-colors duration-300 hover:text-[var(--foreground)] before:absolute before:bottom-0 before:left-0 before:h-[2px] before:w-full before:scale-x-0 before:bg-[var(--foreground)] before:transition-transform before:duration-300 before:ease-out before:origin-right hover:before:scale-x-100 hover:before:origin-left [&.active]:text-[var(--foreground)] [&.active]:before:scale-x-100 [&.active]:before:origin-left"
      >
        Conectar
      </a>
    </nav>

    <!-- RIGHT -->
    <div class="flex items-center justify-center md:justify-end">
      <a
        href="https://linkedin.com/in/max-ebina"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="group relative flex items-center justify-center w-9 h-9 rounded-full border border-border/50 transition-all duration-300 hover:border-foreground/40 hover:bg-foreground/5"
      >
        <i class="ph ph-bold ph-linkedin-logo w-4 h-4 text-muted-foreground transition-colors duration-300 group-hover:text-foreground"></i>
      </a>
    </div>

  </div>

</footer>