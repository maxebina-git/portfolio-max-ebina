---
import '../styles/pages/home.css';

import MainLayout from '../layouts/MainLayout.astro';

import Hero from '../components/Hero.astro';
import Cases from '../components/Cases.astro';
import Sobre from '../components/Sobre.astro';
import Conectar from '../components/Conectar.astro';

export async function getStaticPaths() {
  return [
    { params: { slug: 'cases' } },
    { params: { slug: 'sobre' } },
    { params: { slug: 'conectar' } }
  ];
}

const { slug } = Astro.params;

// fallback seguro
if (!slug) {
  return Astro.redirect('/');
}

// mapeia slug para scroll inicial (opcional mas útil)
const initialSection = slug;
---

<MainLayout>

  <main class="w-full">

    <!-- SEMPRE renderiza tudo -->
    <Hero />
    <Cases />
    <Sobre />
    <Conectar />

  </main>

  <!-- inicialização de posição baseada na URL -->
  <script is:inline>
    window.__INITIAL_SECTION__ = "{initialSection}";
  </script>

</MainLayout>