---
// 🔴 IMPORTANTE: Importa o seu CSS global para ativar o Tailwind v4 e carregar os tokens!
import '../styles/global.css';
import meImage from '../assets/me.png';
---

<html lang="pt-br">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Max.productdesigner | Portfólio</title>
    
    <style>
      /* Configuração das curvas físicas das animações */
      html {
        scroll-behavior: smooth;
        scroll-padding-top: 80px; 
      }

      /* Estado inicial padrão */
      .reveal-item {
        opacity: 0;
        transform: translateX(-60px);
        transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.8s ease;
      }

      /* Estado ativo do script de rolagem */
      .reveal-item.is-visible {
        opacity: 1;
        transform: translateX(0);
      }

      /* Estado de saída */
      .reveal-item.exit-right {
        opacity: 0;
        transform: translateX(60px);
      }

      @keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: .4; transform: scale(1.2); }
      }
      .badge-pulse {
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
      }

      /* =========================================
        CASES CINEMATIC EXPANDING BACKGROUND
      ========================================= */

      #cases {
        position: relative;
        overflow: hidden;
        isolation: isolate;
      }

      /* Retângulo expansivo premium */
      #cases::before {
        content: '';

        position: absolute;
        inset: 0;

        background:
          radial-gradient(
            circle at center,
            #FFEFD6 50%,
            #FFDFB5 100%
          );

        z-index: 0;

        transform: scale(0.12);
        transform-origin: center center;

        opacity: 0;

        filter: blur(18px);

        transition:
          transform 1s cubic-bezier(0.16, 1, 0.3, 1),
          opacity 0.8s ease,
          filter 1s cubic-bezier(0.16, 1, 0.3, 1);

        will-change:
          transform,
          opacity,
          filter;
      }

      #cases.bg-active::before {
        transform: scale(1);
        opacity: 1;
        filter: blur(0px);
      }

      /* DESKTOP */
      @media (min-width: 768px) {
        #cases::before {
          left: 0;
          right: 0;
        }
      }

      /* Estado ativo */
      #cases.bg-active::before {
        transform: scale(1);
        opacity: 1;
        filter: blur(0px);
        border-radius: 0px;
      }

      /* Mantém conteúdo acima */
      #cases > * {
        position: relative;
        z-index: 1;
      }
    </style>
    
    <script is:inline>
      const savedTheme = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      
      if (savedTheme === 'dark' || (!savedTheme && prefersDark)) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
      // FORÇAR REPAINT DO CSS
      window.onload = () => {
        document.body.style.display = 'none';
        document.body.offsetHeight;
        document.body.style.display = '';
      };
    </script>
  </head>
  
  <body class="bg-background text-foreground antialiased min-h-screen transition-colors duration-300 overflow-hidden">

    <div id="fake-loader" class="fixed inset-0 z-[100] bg-background flex flex-col transition-opacity duration-600 ease-in-out pointer-events-auto">
      <div class="w-full h-16 border-b border-border/40 bg-background">
        <div class="max-w-7xl mx-auto px-6 h-full flex items-center justify-end">
          <div class="flex items-center gap-8">
            <div class="flex items-center gap-6">
              <div class="w-10 h-4 bg-neutral-200 dark:bg-neutral-800 rounded"></div>
              <div class="w-20 h-4 bg-neutral-200 dark:bg-neutral-800 rounded"></div>
              <div class="w-10 h-4 bg-neutral-200 dark:bg-neutral-800 rounded"></div>
              <div class="w-14 h-4 bg-neutral-200 dark:bg-neutral-800 rounded"></div>
            </div>
            <div class="w-8 h-8 bg-neutral-200 dark:bg-neutral-800 rounded-full"></div>
          </div>
        </div>
      </div>

      <div class="w-[calc(100%-32px)] md:w-full max-w-7xl mx-auto py-12 grid grid-cols-1 lg:grid-cols-2 gap-12 items-stretch min-h-[calc(100vh-4rem)]">
        <div class="bg-primary/30 dark:bg-primary/20 p-8 md:p-12 rounded-3xl flex flex-col justify-between min-h-[390px] md:min-h-[500px] relative overflow-hidden">
          <div id="loader-fill" class="absolute bottom-0 left-0 w-full bg-primary transition-all duration-400 ease-out z-0" style="height: 0%;"></div>
          <div class="flex-grow"></div>
          <div class="space-y-4 z-10">
            <div class="text-3xl sm:text-4xl md:text-5xl font-black tracking-tight text-white dark:text-foreground leading-tight md:leading-none select-none min-h-[2em] flex items-end">
              <span id="load-text-container">
                <span id="load-percentage">0</span><span id="load-symbol">%</span>
              </span>
            </div>
          </div>
        </div>

        <div class="flex flex-col justify-center space-y-8 pl-0 lg:pl-4">
          <div class="space-y-3">
            <div class="h-10 bg-neutral-200 dark:bg-neutral-800 rounded-xl w-full"></div>
            <div class="h-10 bg-neutral-200 dark:bg-neutral-800 rounded-xl w-3/5"></div>
          </div>
          <div class="space-y-2.5">
            <div class="h-4 bg-neutral-200 dark:bg-neutral-800 rounded-md w-full"></div>
            <div class="h-4 bg-neutral-200 dark:bg-neutral-800 rounded-md w-full"></div>
            <div class="h-4 bg-neutral-200 dark:bg-neutral-800 rounded-md w-11/12"></div>
          </div>
        </div>
      </div>
    </div>

    <header 
      id="main-header" 
      class="sticky top-0 z-50 w-full bg-[var(--muted)]/80 backdrop-blur-md transition-all duration-300 ease-in-out py-4 border-b border-border/40
            [&.header-expanded]:top-2 
            [&.header-expanded]:py-6 
            [&.header-expanded]:mx-auto 
            [&.header-expanded]:w-[calc(100%-16px)] 
            [&.header-expanded]:rounded-2xl 
            [&.header-expanded]:border 
            [&.header-expanded]:border-border/50 
            [&.header-expanded]:shadow-lg"
    >
      <div class="max-w-7xl mx-auto px-6 flex items-center justify-end">
        <div class="flex items-center gap-8 transition-all duration-300">
          <nav class="flex items-center">
            <div class="flex items-center gap-6 text-sm font-medium text-[var(--muted-foreground)]">
              <a href="#cases" class="nav-link relative py-1 transition-colors duration-300 hover:text-[var(--foreground)] before:absolute before:bottom-0 before:left-0 before:h-[2px] before:w-full before:scale-x-0 before:bg-[var(--foreground)] before:transition-transform before:duration-300 before:ease-out before:origin-right hover:before:scale-x-100 hover:before:origin-left [&.active]:text-[var(--foreground)] [&.active]:before:scale-x-100 [&.active]:before:origin-left">Cases</a>
              <a href="#ecossistema" class="nav-link relative py-1 transition-colors duration-300 hover:text-[var(--foreground)] before:absolute before:bottom-0 before:left-0 before:h-[2px] before:w-full before:scale-x-0 before:bg-[var(--foreground)] before:transition-transform before:duration-300 before:ease-out before:origin-right hover:before:scale-x-100 hover:before:origin-left [&.active]:text-[var(--foreground)] [&.active]:before:scale-x-100 [&.active]:before:origin-left">Ecossistema</a>
              <a href="#sobre" class="nav-link relative py-1 transition-colors duration-300 hover:text-[var(--foreground)] before:absolute before:bottom-0 before:left-0 before:h-[2px] before:w-full before:scale-x-0 before:bg-[var(--foreground)] before:transition-transform before:duration-300 before:ease-out before:origin-right hover:before:scale-x-100 hover:before:origin-left [&.active]:text-[var(--foreground)] [&.active]:before:scale-x-100 [&.active]:before:origin-left">Sobre</a>
              <a href="#conectar" class="nav-link relative py-1 transition-colors duration-300 hover:text-[var(--foreground)] before:absolute before:bottom-0 before:left-0 before:h-[2px] before:w-full before:scale-x-0 before:bg-[var(--foreground)] before:transition-transform before:duration-300 before:ease-out before:origin-right hover:before:scale-x-100 hover:before:origin-left [&.active]:text-[var(--foreground)] [&.active]:before:scale-x-100 [&.active]:before:origin-left">Conectar</a>
            </div>
          </nav>

          <button id="theme-toggle" aria-label="Alternar tema escuro/claro" class="w-8 h-8 flex items-center justify-center text-xl bg-transparent border-none outline-none transition-transform active:scale-90 cursor-pointer">
            <span id="toggle-icon">🌑</span>
          </button>
        </div>
      </div>
    </header>

    <main class="w-full">
      
      <section 
        id="hero" 
        class="content-section max-w-7xl mx-auto px-4 md:px-0 py-12 grid grid-cols-1 lg:grid-cols-2 gap-12 items-stretch min-h-[calc(100vh-4rem)]"
      >
        
        <div class="bg-primary p-8 md:p-12 rounded-3xl flex flex-col justify-between text-primary-foreground min-h-[460px] md:min-h-[500px]">
          
          <div class="flex-grow flex items-center justify-center">
            <img src={meImage.src} alt="Logo ME" class="w-48 h-auto opacity-90" />
          </div>
          
          <div class="space-y-4">
            <a href="#hero" id="logo-link" class="active relative inline-block transition-colors duration-300 before:absolute before:-bottom-2 before:left-0 before:h-[3px] before:w-full before:scale-x-0 before:bg-white before:transition-transform before:duration-300 before:ease-out before:origin-right hover:before:scale-x-100 hover:before:origin-left [&.active]:before:scale-x-100 [&.active]:before:origin-left">
              <h1 class="text-3xl sm:text-4xl md:text-5xl font-black tracking-tight leading-tight md:leading-none flex flex-col md:block">
                <span class="text-white/90 md:text-white">Max</span>
                <span class="text-white/90 md:text-white">productdesigner</span>
              </h1>
            </a>
            <div class="pt-2">
              <span class="inline-block bg-white/20 backdrop-blur-sm text-xs font-semibold px-3 py-1 rounded-full whitespace-nowrap text-white/90">
                Disponível para propostas
              </span>
            </div>
          </div>
        </div>

        <div class="flex flex-col justify-center space-y-8 pl-0 lg:pl-4">
          <h2 class="text-3xl md:text-5xl font-black tracking-tight leading-tight text-foreground">
            Conectando dados, pixel e código sem fricção.
          </h2>
          <p class="text-base md:text-lg text-muted-foreground leading-relaxed font-normal">
            Construo interfaces de alta fidelidade baseadas em dados, pesquisas e usabilidade. Através de uma esteira robusta di DesignOps e tokens estruturados, garanto consistência cirúrgica entre design e produção, acelerando a entrega de engenharia e eliminando erros de comunicação.
          </p>

          <div class="space-y-6 pt-4 border-t border-border/60">
            <div class="space-y-1">
              <h3 class="font-bold text-foreground text-base flex items-center gap-2">
                <span>🧠</span> Engenharia de Usabilidade
              </h3>
              <p class="text-sm text-muted-foreground pl-7">
                Discovery baseado em dados, mapeamento de jornadas e testes iterativos para mitigar riscos e garantir solutions validadas com o usuário final.
              </p>
            </div>
            <div class="space-y-1">
              <h3 class="font-bold text-foreground text-base flex items-center gap-2">
                <span>📐</span> UI Pixel-Perfect
              </h3>
              <p class="text-sm text-muted-foreground pl-7">
                Interfaces impecáveis, consistência visual rigorosa e layouts fluidos que se adaptam nativamente a qualquer dispositivo.
              </p>
            </div>
            <div class="space-y-1">
              <h3 class="font-bold text-foreground text-base flex items-center gap-2">
                <span>⚙️</span> DesignOps & Automação
              </h3>
              <p class="text-sm text-muted-foreground pl-7">
                Governança de Design System, automação de tokens e esteiras de código limpo que eliminam o retrabalho e garantem a escalabilidade da interface.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section 
        id="cases" 
        class="content-section relative overflow-hidden isolation-isolate w-[calc(100%-32px)] md:w-full max-w-7xl mx-auto rounded-[32px] py-16"
      >
        <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-12">
          <div class="reveal-item bg-accent/10 p-12 rounded-3xl border border-border flex items-center justify-center min-h-[300px]">
            <h2 class="text-4xl font-black tracking-tight text-foreground">Cases</h2>
          </div>
          <div class="reveal-item flex flex-col justify-center" style="transition-delay: 200ms;">
            <p class="text-xl text-muted-foreground">Conteúdo do Cases aqui...</p>
          </div>
        </div>
      </section>

      <section id="ecossistema" class="content-section max-w-7xl mx-auto px-4 md:px-6 rounded-3xl py-16">
        <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-12">
          <div class="reveal-item flex flex-col justify-center">
            <p class="text-xl text-muted-foreground">Conteúdo do Ecossistema aqui...</p>
          </div>
          <div class="reveal-item bg-accent/10 p-12 rounded-3xl border border-border flex items-center justify-center min-h-[300px]" style="transition-delay: 200ms;">
            <h2 class="text-4xl font-black tracking-tight text-foreground">Ecossistema</h2>
          </div>
        </div>
      </section>

      <section id="sobre" class="content-section max-w-7xl mx-auto px-4 md:px-6 rounded-3xl py-16">
        <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-12">
          <div class="reveal-item bg-accent/10 p-12 rounded-3xl border border-border flex items-center justify-center min-h-[300px]">
            <h2 class="text-4xl font-black tracking-tight text-foreground">Max</h2>
          </div>
          <div class="reveal-item flex flex-col justify-center" style="transition-delay: 200ms;">
            <p class="text-xl text-muted-foreground">Conteúdo sobre você...</p>
          </div>
        </div>
      </section>

      <section id="conectar" class="content-section max-w-7xl mx-auto px-4 md:px-6 rounded-3xl py-16">
        <div class="max-w-3xl mx-auto px-6 text-center space-y-6">
          <h2 class="reveal-item text-4xl font-black tracking-tight text-foreground">Vamos transformar design em código escalável?</h2>
          <p class="reveal-item text-lg text-muted-foreground" style="transition-delay: 150ms;">Fique à vontade para me acionar para contratos, consultorias de DesignOps ou posições core de Product Design.</p>
          <div class="reveal-item pt-4" style="transition-delay: 300ms;">
            <a href="mailto:seu-email@dominio.com" class="inline-flex bg-primary text-primary-foreground font-semibold px-8 py-4 rounded-xl text-lg hover:bg-primary/90 transition-all shadow-md">
              Iniciar Conversa
            </a>
          </div>
        </div>
      </section>

      <footer 
        id="main-footer" 
        class="w-[calc(100%-16px)] mx-auto mb-2 rounded-2xl border border-border/60 bg-[var(--muted)]/80 backdrop-blur-md 
              shadow-[0_-8px_32px_rgba(0,0,0,0.06)] 
              dark:shadow-[0_-8px_32px_rgba(0,0,0,0.4)] 
              py-10 text-center text-xs text-neutral-400"
      >
        <p>© {new Date().getFullYear()} Max.productdesigner. Todos os direitos reservados.</p>
      </footer>

    </main>

    <script>
      let lastScrollTop = window.scrollY;
      let isClicking = false;
      const navLinks = document.querySelectorAll('.nav-link');
      const logoLink = document.getElementById('logo-link'); 
      const mainHeader = document.getElementById('main-header');

      // --- LÓGICA DE LOADING ---
      window.addEventListener('DOMContentLoaded', () => {
        const loader = document.getElementById('fake-loader');
        const percentageText = document.getElementById('load-percentage');
        const fill = document.getElementById('loader-fill');
        let currentPercent = 0;

        if (fill) fill.style.height = '0%';
        if (percentageText) percentageText.textContent = '0';

        const interval = setInterval(() => {
          if (currentPercent < 100) {
            currentPercent += Math.floor(Math.random() * 8) + 2;
            if (currentPercent > 100) currentPercent = 100;
            
            if (percentageText) percentageText.textContent = `${currentPercent}`;
            if (fill) fill.style.height = `${currentPercent}%`;
          } else {
            clearInterval(interval);
            setTimeout(() => {
              if (loader) {
                loader.style.opacity = '0';
                loader.style.pointerEvents = 'none';
                setTimeout(() => {
                  loader.remove();
                  document.body.classList.remove('overflow-hidden');
                }, 600);
              }
            }, 300);
          }
        }, 100);
      });

      // --- LÓGICA DE ALTERNÂNCIA DE TEMA ---
      const themeToggle = document.getElementById('theme-toggle');
      const toggleIcon = document.getElementById('toggle-icon');

      function updateToggleIcon() {
        if (document.documentElement.classList.contains('dark')) {
          toggleIcon.textContent = '🌕';
        } else {
          toggleIcon.textContent = '🌑';
        }
      }

      updateToggleIcon();

      if (themeToggle) {
        themeToggle.addEventListener('click', () => {
          if (document.documentElement.classList.contains('dark')) {
            document.documentElement.classList.remove('dark');
            localStorage.setItem('theme', 'light');
          } else {
            document.documentElement.classList.add('dark');
            localStorage.setItem('theme', 'dark');
          }
          updateToggleIcon();
        });
      }

      // --- INTERAÇÃO DO CLIQUE NO LOGO ---
      if (logoLink) {
        logoLink.addEventListener('click', (e) => {
          e.preventDefault(); 
          isClicking = true;
          navLinks.forEach(l => l.classList.remove('active'));
          logoLink.classList.add('active');
          window.scrollTo({ top: 0, behavior: 'smooth' });
          history.pushState(null, '', '/');
          setTimeout(() => { isClicking = false; }, 800);
        });
      }

      // --- NAVEGAÇÃO DO MENU ---
      navLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault(); 
          isClicking = true;
          navLinks.forEach(l => l.classList.remove('active'));
          if (logoLink) logoLink.classList.remove('active'); 
          link.classList.add('active');

          const targetId = link.getAttribute('href'); 
          const targetSection = document.querySelector(targetId);
          const routeName = targetId.replace('#', ''); 

          if (targetSection) {
            const targetPosition = targetSection.getBoundingClientRect().top + window.scrollY - 80;
            window.scrollTo({ top: targetPosition, behavior: 'smooth' });
            history.pushState(null, '', `/${routeName}`);
          }
          setTimeout(() => { isClicking = false; }, 800);
        });
      });

      // --- OBSERVAÇÃO DO SCROLL ---
      const observerOptions = {
        root: null,
        rootMargin: "-30% 0px -50% 0px", 
        threshold: 0.15
      };

      const observer = new IntersectionObserver((entries) => {
        const isScrollingDown = window.scrollY > lastScrollTop;
        lastScrollTop = window.scrollY;

        entries.forEach(entry => {
          const section = entry.target;
          const animatableItems = section.querySelectorAll('.reveal-item');
          const sectionId = section.getAttribute('id');

          if (entry.isIntersecting) {
            // Ativa o background e itens
            section.classList.add('bg-active'); 
            if (sectionId !== 'hero' && logoLink) logoLink.classList.remove('active');

            animatableItems.forEach(item => {
              item.classList.remove('exit-right');
              item.classList.add('is-visible');
            });

            if (!isClicking) {
              navLinks.forEach(link => {
                if (link.getAttribute('href') === `#${sectionId}`) {
                  link.classList.add('active');
                  history.pushState(null, '', `/${sectionId}`);
                } else {
                  link.classList.remove('active');
                }
              });
            }
          } else {
            // Remove o background e itens
            section.classList.remove('bg-active');
            if (isScrollingDown) {
              animatableItems.forEach(item => {
                item.classList.remove('is-visible');
                item.classList.add('exit-right');
              });
            } else {
              animatableItems.forEach(item => {
                item.classList.remove('is-visible', 'exit-right');
              });
            }
          }
        });
      }, observerOptions);

      document.querySelectorAll('.content-section').forEach(section => {
        observer.observe(section);
      });

      // --- CONTROLE DO HEADER ---
      window.addEventListener('scroll', () => {
        if (window.scrollY > 100) {
          if (mainHeader) mainHeader.classList.add('header-expanded');
        } else {
          if (mainHeader) mainHeader.classList.remove('header-expanded');
        }

        if (window.scrollY < 100 && !isClicking) {
          navLinks.forEach(l => l.classList.remove('active'));
          if (logoLink) logoLink.classList.add('active'); 
          if (window.location.pathname !== '/') history.pushState(null, '', '/');
        }
      });
    </script>
  </body>
</html>