---
import '../styles/global.css';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CaseModal from '../components/CaseModal.astro';
---

<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <title>Max Ebina — Product Designer</title>

    <meta
      name="description"
      content="Portfolio de Max Ebina — Product Designer especializado em interfaces de alta fidelidade, DesignOps e experiências orientadas por dados."
    />

    <link rel="icon" href="/favicon.ico" />

    <script src="https://unpkg.com/@phosphor-icons/web"></script>
  </head>

  <body
    class="overflow-x-hidden"
    style="background-color: var(--background); color: var(--foreground);"
  >

    <Header />

    <main>
      <slot />
    </main>

    <Footer />

    <CaseModal />

    <button
      id="back-to-top"
      aria-label="Voltar ao topo"
      class="fixed right-6 bottom-7.5 z-50
        opacity-0 scale-90 pointer-events-none
        transition-all duration-300
        w-10 h-10 rounded-full
        border border-border/50
        bg-background/80 backdrop-blur
        text-muted-foreground
        hover:border-foreground/40
        hover:bg-foreground/5
        hover:text-foreground
        cursor-pointer"
    >
      <i class="ph ph-bold ph-arrow-up"></i>
    </button>

    <script>
      import '../scripts/app.js';
    </script>

  </body>
</html>