---
import '../styles/global.css';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Max Ebina — Product Designer</title>

    <meta
      name="description"
      content="Portfolio de Max Ebina — Product Designer especializado em interfaces de alta fidelidade, DesignOps e experiências orientadas por dados."
    />
  </head>

  <body
    class="overflow-x-hidden"
    style="background-color: var(--background); color: var(--foreground);"
  >

    <Header />

    <main>
      <slot />
    </main>

    <Footer />

    <script type="module" src="/src/scripts/app.js"></script>

  </body>
</html>